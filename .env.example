# Optional local GIS stack overrides.
# The application still uses H2 by default unless the postgis Spring profile is enabled.

POSTGIS_IMAGE=postgis/postgis:16-3.4
POSTGIS_DB=geostatusboard
POSTGIS_USER=gsb
POSTGIS_PASSWORD=gsb
POSTGIS_PORT=5432
POSTGIS_SCHEMA=public

GEOSERVER_IMAGE=docker.osgeo.org/geoserver:2.28.2
GEOSERVER_PORT=8081
GEOSERVER_ADMIN_USER=admin
GEOSERVER_ADMIN_PASSWORD=geoserver
GEOSERVER_WORKSPACE=gsb
GEOSERVER_STORE=postgis
GEOSERVER_WFS_URL=http://localhost:8081/geoserver/gsb/ows
GEOSERVER_REQUEST_TIMEOUT_MS=5000
GEOSERVER_WFS_MAX_FEATURES=5000
GEOSERVER_CORS_ALLOWED_ORIGINS=*

GEOAI_CONTEXT=../geoai-asset-detection-platform
GEOAI_IMAGE=geoai-road-detection-platform:dev
GEOAI_PORT=8000
GEOAI_WORKFLOW_CATALOG=config/workflows.example.yaml
GEOAI_DOWNLOAD_HF_MODEL=true
GEOAI_DOWNLOAD_HF_BUILDING_MODEL=true
GEOAI_FETCH_SAMPLE_COG=true
GEOAI_CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:18088,http://127.0.0.1:18088,http://localhost:18192,http://127.0.0.1:18192

OPENCLAW_ENABLED=true
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
OPENCLAW_MSTEAMS_PORT=3978
OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_GATEWAY_URL=http://localhost:18789
OPENCLAW_HEALTH_URL=http://localhost:18789/healthz
OPENCLAW_READY_URL=http://localhost:18789/readyz
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_ALLOW_INSECURE_PRIVATE_WS=
OPENCLAW_DISABLE_BONJOUR=1
OPENCLAW_TZ=UTC
